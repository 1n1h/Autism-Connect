# TEMPLATE ONLY. Copy to .env.local and fill in your real values.
# DO NOT put real secrets in this file — it IS committed to git.
# .env.local is gitignored.

# ---- Supabase ----
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # "publishable" key (sb_publishable_...)
SUPABASE_SERVICE_ROLE_KEY=            # "secret" key — server only, bypasses RLS

# ---- Admin Authentication (Phase 6) ----
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=                  # bcrypt hash — Phase 6 sets this up
ADMIN_JWT_SECRET=                     # generate: openssl rand -base64 48

# ---- Together AI (Phase 5) ----
TOGETHER_AI_API_KEY=
TOGETHER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# ---- Resend email ----
RESEND_API_KEY=
# Until you own a verified domain, use Resend's shared sender:
RESEND_FROM_EMAIL=AutismConnect <onboarding@resend.dev>

# ---- Stripe (Phase 7) ----
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=                # from `stripe listen` or webhook endpoint

# ---- Next.js ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
